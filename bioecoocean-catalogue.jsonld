      ],
      "@context": "https://schema.org/",
      "@id": "https://raw.githubusercontent.com/BioEcoOcean/data-prov/refs/heads/main/jsonFiles/zenodo/initial-conceptual-design-of-the-blueprint-for-integrated-ocean-science-15655871.json"

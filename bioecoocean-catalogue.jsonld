    {
      "@type": "CreativeWork",
      "name": "EOV Network Clustering Event Nr 2: Collection of the presentations",
      "url": "https://zenodo.org/record/20325734",
      "identifier": {
        "@type": "PropertyValue",
        "description": "DOI",
        "propertyID": "https://registry.identifiers.org/registry/doi",

          "name": "Lawrence, Elizabeth"
        },
        {
          "@type": "Person",
          "name": "Lepola, Nina"
        },
        {
          "@type": "Person",
          "name": "Lara-Lopez, Ana"
        },
        {
          "@type": "Person",
          "name": "Palacz, Artur"
        }
      ],
      "license": {
        "id": "cc-by-4.0"
      },
      "funding": [
